{
  "name": "galaxy-downloader-cli",
  "version": "1.0.0",
  "description": "CLI tool for downloading media from Bilibili, Douyin, Instagram, Xiaohongshu, TikTok, X and more",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "galaxy-downloader": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "keywords": [
    "download",
    "video",
    "audio",
    "bilibili",
    "douyin",
    "tiktok",
    "instagram",
    "xiaohongshu"
  ],
  "author": "galaxy-downloader",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}